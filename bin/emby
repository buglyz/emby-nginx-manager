#!/bin/sh
set -eu

SCRIPT="${EMBY_NGINX_MANAGER_SCRIPT:-/opt/emby-nginx-manager/deploy.sh}"
SERVICE_NAME="${EMBY_NGINX_MANAGER_WEBUI_SERVICE:-emby-nginx-webui.service}"
ENV_FILE="${EMBY_NGINX_MANAGER_WEBUI_ENV:-/etc/emby-nginx-webui.env}"
UNIT_FILE="/etc/systemd/system/$SERVICE_NAME"
WEBUI_HTPASSWD="${EMBY_NGINX_MANAGER_WEBUI_HTPASSWD:-/etc/nginx/.htpasswd-emby-webui}"
WEBUI_KEY_SNIPPET="${EMBY_NGINX_MANAGER_WEBUI_KEY_SNIPPET:-/etc/nginx/snippets/emby-webui-internal-key.conf}"
NGINX_CONF_DIR="${NGINX_CONF_DIR:-/etc/nginx/conf.d}"
TMP_FILES=""

cleanup_tmp_files() {
    for tmp_file in $TMP_FILES; do
        rm -f "$tmp_file"
    done
}

make_tmp_file() {
    target_var="$1"
    case "$target_var" in
        *[!A-Za-z0-9_]*|"")
            echo "错误: 临时文件变量名无效。" >&2
            exit 1
            ;;
    esac
    tmp_file=$(mktemp)
    TMP_FILES="${TMP_FILES}${TMP_FILES:+ }$tmp_file"
    eval "$target_var=\$tmp_file"
}

forget_tmp_file() {
    remove_tmp="$1"
    kept=""
    for tmp_file in $TMP_FILES; do
        if [ "$tmp_file" != "$remove_tmp" ]; then
            kept="${kept}${kept:+ }$tmp_file"
        fi
    done
    TMP_FILES="$kept"
}

remove_tmp_file() {
    tmp_file="$1"
    rm -f "$tmp_file"
    forget_tmp_file "$tmp_file"
}

trap cleanup_tmp_files EXIT
trap 'cleanup_tmp_files; exit 129' HUP
trap 'cleanup_tmp_files; exit 130' INT
trap 'cleanup_tmp_files; exit 143' TERM

if [ ! -f "$SCRIPT" ]; then
    SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)
    SCRIPT="$SCRIPT_DIR/deploy.sh"
fi

if [ ! -f "$SCRIPT" ]; then
    echo "错误: 找不到 Emby Nginx 管理脚本。" >&2
    exit 1
fi

resolve_webui() {
    WEBUI="${EMBY_NGINX_MANAGER_WEBUI:-$(dirname "$SCRIPT")/webui.py}"
    if [ ! -f "$WEBUI" ]; then
        SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)
        WEBUI="$SCRIPT_DIR/webui.py"
    fi
    if [ ! -f "$WEBUI" ]; then
        echo "错误: 找不到 Emby Nginx WebUI。" >&2
        exit 1
    fi
    printf '%s\n' "$WEBUI"
}

need_python() {
    if ! command -v python3 >/dev/null 2>&1; then
        echo "错误: WebUI 需要 python3。" >&2
        exit 1
    fi
}

need_systemctl() {
    if ! command -v systemctl >/dev/null 2>&1; then
        echo "错误: 当前系统没有 systemctl，无法管理后台服务。" >&2
        exit 1
    fi
}

validate_service_name() {
    case "$SERVICE_NAME" in
        *.service)
            ;;
        *)
            echo "错误: WebUI 服务名必须以 .service 结尾。" >&2
            exit 1
            ;;
    esac
    case "$SERVICE_NAME" in
        ""|*..*|*[!A-Za-z0-9_.@-]*)
            echo "错误: WebUI 服务名格式无效。" >&2
            exit 1
            ;;
    esac
}

validate_config_path() {
    value="$1"
    label="$2"
    case "$value" in
        /*)
            ;;
        *)
            echo "错误: $label 必须使用绝对路径。" >&2
            exit 1
            ;;
    esac
    case "$value" in
        *[![:print:]]*|*[[:space:]]*|*";"*|*"{"*|*"}"*|*"'"*|*"\""*|*"\\"*)
            echo "错误: $label 路径包含不支持的字符。" >&2
            exit 1
            ;;
    esac
}

setup_sudo() {
    SUDO=""
    if [ "$(id -u)" -ne 0 ]; then
        if ! command -v sudo >/dev/null 2>&1; then
            echo "错误: 请使用 root 运行，或先安装 sudo。" >&2
            exit 1
        fi
        SUDO="sudo"
    fi
}

generate_access_key() {
    python3 -c 'import secrets; print(secrets.token_urlsafe(32))'
}

ensure_webui_env() {
    if $SUDO test -f "$ENV_FILE"; then
        if ! $SUDO grep -q '^EMBY_WEBUI_KEY=' "$ENV_FILE"; then
            key=$(generate_access_key)
            printf '\nEMBY_WEBUI_KEY=%s\n' "$key" | $SUDO tee -a "$ENV_FILE" >/dev/null
        fi
        $SUDO chmod 600 "$ENV_FILE"
        return
    fi

    make_tmp_file tmp_env
    chmod 600 "$tmp_env"
    key=$(generate_access_key)
    printf 'EMBY_WEBUI_KEY=%s\n' "$key" > "$tmp_env"
    $SUDO install -m 600 "$tmp_env" "$ENV_FILE"
    remove_tmp_file "$tmp_env"
}

install_web_service() {
    setup_sudo
    need_systemctl
    validate_service_name
    validate_config_path "$ENV_FILE" "WebUI 环境文件"
    need_python
    WEBUI=$(resolve_webui)
    PYTHON_BIN=$(command -v python3)
    WORKDIR=$(CDPATH= cd -- "$(dirname -- "$SCRIPT")" && pwd)

    ensure_webui_env

    make_tmp_file tmp_unit
    cat > "$tmp_unit" <<EOF
[Unit]
Description=Emby Nginx Manager WebUI
After=network.target
StartLimitIntervalSec=60
StartLimitBurst=10

[Service]
Type=simple
WorkingDirectory=$WORKDIR
EnvironmentFile=$ENV_FILE
Environment=EMBY_WEBUI_SHOW_KEY_URL=0
ExecStart=$PYTHON_BIN $WEBUI --script $SCRIPT
Restart=on-failure
RestartSec=2
KillMode=mixed
TimeoutStopSec=15
NoNewPrivileges=true
UMask=0077
PrivateTmp=true
PrivateDevices=true
ProtectHome=true
ProtectClock=true
ProtectControlGroups=true
ProtectHostname=true
ProtectKernelModules=true
ProtectKernelTunables=true
LockPersonality=true
RemoveIPC=true
RestrictNamespaces=true
RestrictSUIDSGID=true
RestrictRealtime=true
SystemCallArchitectures=native

[Install]
WantedBy=multi-user.target
EOF

    $SUDO install -m 644 "$tmp_unit" "$UNIT_FILE"
    remove_tmp_file "$tmp_unit"
    $SUDO systemctl daemon-reload
    $SUDO systemctl enable "$SERVICE_NAME" >/dev/null
    $SUDO systemctl restart "$SERVICE_NAME"

    echo "WebUI 服务已安装并启动: $SERVICE_NAME"
    echo "查看状态: emby web-status"
    echo "查看日志: emby web-logs"
}

service_action() {
    action="$1"
    setup_sudo
    need_systemctl
    validate_service_name
    $SUDO systemctl "$action" "$SERVICE_NAME"
}

service_status() {
    setup_sudo
    need_systemctl
    validate_service_name
    $SUDO systemctl status "$SERVICE_NAME" --no-pager
}

service_logs() {
    setup_sudo
    need_systemctl
    validate_service_name
    if [ "$#" -eq 0 ]; then
        set -- -n 100 --no-pager
    fi
    exec $SUDO journalctl -u "$SERVICE_NAME" "$@"
}

validate_proxy_domain() {
    domain="$1"
    case "$domain" in
        ""|*" "*|*"/"*|*":"*|*"*"*|*";"*|*"'"*|*"\""*|*"\\"*)
            echo "错误: WebUI 反代域名格式无效。" >&2
            exit 1
            ;;
    esac
}

validate_basic_user() {
    user="$1"
    case "$user" in
        ""|*[!A-Za-z0-9_.-]*)
            echo "错误: Basic Auth 用户名只能包含字母、数字、点、下划线或短横线。" >&2
            exit 1
            ;;
    esac
}

validate_password_file() {
    if [ -n "${password_file:-}" ] && [ ! -f "$password_file" ]; then
        echo "错误: Basic Auth 密码文件不存在或不是普通文件。" >&2
        exit 1
    fi
}

read_webui_key() {
    validate_config_path "$ENV_FILE" "WebUI 环境文件"
    if ! $SUDO test -f "$ENV_FILE"; then
        echo "错误: 找不到 $ENV_FILE，请先运行 emby web-install。" >&2
        exit 1
    fi
    key=$($SUDO awk -F= '$1 == "EMBY_WEBUI_KEY" { print $2; exit }' "$ENV_FILE")
    case "$key" in
        ""|*[!A-Za-z0-9_.-]*)
            echo "错误: $ENV_FILE 中的 EMBY_WEBUI_KEY 无效。" >&2
            exit 1
            ;;
    esac
    printf '%s\n' "$key"
}

detect_webui_cert() {
    domain="$1"
    if $SUDO test -f "/etc/nginx/ssl/$domain/fullchain.pem" && $SUDO test -f "/etc/nginx/ssl/$domain/privkey.pem"; then
        printf '%s|%s\n' "/etc/nginx/ssl/$domain/fullchain.pem" "/etc/nginx/ssl/$domain/privkey.pem"
        return 0
    fi
    if $SUDO test -f "/etc/nginx/certs/$domain/cert" && $SUDO test -f "/etc/nginx/certs/$domain/key"; then
        printf '%s|%s\n' "/etc/nginx/certs/$domain/cert" "/etc/nginx/certs/$domain/key"
        return 0
    fi
    return 1
}

read_basic_password() {
    if [ -n "${EMBY_WEBUI_BASIC_PASSWORD:-}" ]; then
        printf '%s\n' "$EMBY_WEBUI_BASIC_PASSWORD"
        return 0
    fi
    if [ -n "${password_file:-}" ]; then
        sed -n '1p' "$password_file"
        return 0
    fi
    if [ -t 0 ]; then
        printf '请输入 WebUI Basic Auth 密码: ' >&2
        saved_tty=$(stty -g)
        stty -echo
        if ! IFS= read -r password; then
            stty "$saved_tty"
            printf '\n' >&2
            echo "错误: 读取 Basic Auth 密码失败。" >&2
            exit 1
        fi
        stty "$saved_tty"
        printf '\n' >&2
        printf '%s\n' "$password"
        return 0
    fi
    echo "错误: 首次创建 htpasswd 需要交互输入密码，或设置 EMBY_WEBUI_BASIC_PASSWORD / --password-file。" >&2
    exit 1
}

install_htpasswd_if_needed() {
    basic_user="$1"
    web_group=""
    if $SUDO test -f "$WEBUI_HTPASSWD"; then
        return 0
    fi
    if ! command -v openssl >/dev/null 2>&1; then
        echo "错误: 创建 Basic Auth 需要 openssl。" >&2
        exit 1
    fi
    password=$(read_basic_password)
    if [ -z "$password" ]; then
        echo "错误: Basic Auth 密码不能为空。" >&2
        exit 1
    fi
    hash=$(printf '%s\n' "$password" | openssl passwd -apr1 -stdin)
    make_tmp_file tmp_htpasswd
    printf '%s:%s\n' "$basic_user" "$hash" > "$tmp_htpasswd"
    for candidate in nginx www-data http; do
        if getent group "$candidate" >/dev/null 2>&1; then
            web_group="$candidate"
            break
        fi
    done
    if [ -n "$web_group" ]; then
        $SUDO install -m 640 -g "$web_group" "$tmp_htpasswd" "$WEBUI_HTPASSWD"
    else
        $SUDO install -m 644 "$tmp_htpasswd" "$WEBUI_HTPASSWD"
    fi
    remove_tmp_file "$tmp_htpasswd"
}

install_web_proxy() {
    setup_sudo
    need_python
    validate_config_path "$ENV_FILE" "WebUI 环境文件"
    validate_config_path "$WEBUI_HTPASSWD" "Basic Auth 文件"
    validate_config_path "$WEBUI_KEY_SNIPPET" "内部密钥 snippet"
    validate_config_path "$NGINX_CONF_DIR" "Nginx 配置目录"
    if ! command -v nginx >/dev/null 2>&1; then
        echo "错误: 找不到 nginx。" >&2
        exit 1
    fi

    proxy_domain=""
    basic_user="${EMBY_WEBUI_BASIC_USER:-admin}"
    password_file=""
    force="no"
    while [ "$#" -gt 0 ]; do
        case "$1" in
            --user)
                if [ "$#" -lt 2 ]; then
                    echo "错误: --user 需要参数。" >&2
                    exit 1
                fi
                basic_user="${2:-}"
                shift 2
                ;;
            --password-file)
                if [ "$#" -lt 2 ]; then
                    echo "错误: --password-file 需要参数。" >&2
                    exit 1
                fi
                password_file="${2:-}"
                shift 2
                ;;
            --force)
                force="yes"
                shift
                ;;
            -*)
                echo "错误: 未知参数 $1" >&2
                exit 1
                ;;
            *)
                if [ -n "$proxy_domain" ]; then
                    echo "错误: 只能指定一个 WebUI 反代域名。" >&2
                    exit 1
                fi
                proxy_domain="$1"
                shift
                ;;
        esac
    done

    validate_proxy_domain "$proxy_domain"
    validate_basic_user "$basic_user"
    validate_password_file
    webui_key=$(read_webui_key)
    cert_pair=$(detect_webui_cert "$proxy_domain") || {
        echo "错误: 未找到 $proxy_domain 的 Nginx 证书。" >&2
        echo "支持路径: /etc/nginx/ssl/$proxy_domain/fullchain.pem 或 /etc/nginx/certs/$proxy_domain/cert" >&2
        exit 1
    }
    cert_file=${cert_pair%%|*}
    key_file=${cert_pair#*|}

    conf_file="$NGINX_CONF_DIR/$proxy_domain-443.conf"
    if $SUDO test -f "$conf_file" && ! $SUDO grep -q 'nre_webui_managed=true' "$conf_file"; then
        if [ "$force" != "yes" ]; then
            echo "错误: $conf_file 已存在且不是本命令管理的配置。需要覆盖请加 --force。" >&2
            exit 1
        fi
    fi

    install_htpasswd_if_needed "$basic_user"

    $SUDO install -d "$(dirname "$WEBUI_KEY_SNIPPET")" "$NGINX_CONF_DIR"
    make_tmp_file tmp_snippet
    printf 'proxy_set_header X-Emby-Webui-Key "%s";\n' "$webui_key" > "$tmp_snippet"
    $SUDO install -m 600 "$tmp_snippet" "$WEBUI_KEY_SNIPPET"
    remove_tmp_file "$tmp_snippet"

    backup_conf=""
    if $SUDO test -f "$conf_file"; then
        make_tmp_file backup_conf
        $SUDO cp "$conf_file" "$backup_conf"
    fi

    make_tmp_file tmp_conf
    cat > "$tmp_conf" <<EOF
# managed_by=emby-nginx-manager-webui
# nre_webui_managed=true
# domain=$proxy_domain

server {
    listen 80;
    listen [::]:80;
    server_name $proxy_domain;

    location ^~ /.well-known/acme-challenge/ {
        root /usr/share/nginx/html;
        default_type text/plain;
        try_files \$uri =404;
    }

    return 301 https://\$host\$request_uri;
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name $proxy_domain;

    ssl_certificate     $cert_file;
    ssl_certificate_key $key_file;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers off;

    location / {
        auth_basic "Emby Nginx Manager";
        auth_basic_user_file $WEBUI_HTPASSWD;
        include $WEBUI_KEY_SNIPPET;

        proxy_pass http://127.0.0.1:8765;
        proxy_http_version 1.1;

        proxy_set_header Host \$host;
        proxy_set_header X-Real-IP \$remote_addr;
        proxy_set_header X-Forwarded-For \$proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto \$scheme;
        proxy_set_header X-Forwarded-Host \$host;
        proxy_set_header X-Forwarded-Port \$server_port;
        proxy_set_header Authorization "";

        proxy_set_header Upgrade \$http_upgrade;
        proxy_set_header Connection "";

        proxy_buffering off;
        proxy_read_timeout 3600s;
        proxy_send_timeout 3600s;
    }
}
EOF
    $SUDO install -m 640 "$tmp_conf" "$conf_file"
    remove_tmp_file "$tmp_conf"

    if ! $SUDO nginx -t; then
        if [ -n "$backup_conf" ]; then
            $SUDO cp "$backup_conf" "$conf_file"
        else
            $SUDO rm -f "$conf_file"
        fi
        [ -n "$backup_conf" ] && remove_tmp_file "$backup_conf"
        echo "错误: Nginx 配置测试失败，已回滚。" >&2
        exit 1
    fi
    [ -n "$backup_conf" ] && remove_tmp_file "$backup_conf"
    $SUDO nginx -s reload
    echo "WebUI 公网反代已安装: https://$proxy_domain/"
}

if [ "${1:-}" = "web" ] || [ "${1:-}" = "webui" ]; then
    shift
    need_python
    WEBUI=$(resolve_webui)
    exec python3 "$WEBUI" --script "$SCRIPT" "$@"
fi

case "${1:-}" in
    web-install|webui-install)
        shift
        install_web_service "$@"
        exit 0
        ;;
    web-start|webui-start)
        shift
        service_action start
        exit 0
        ;;
    web-stop|webui-stop)
        shift
        service_action stop
        exit 0
        ;;
    web-restart|webui-restart)
        shift
        service_action restart
        exit 0
        ;;
    web-status|webui-status)
        shift
        service_status
        exit 0
        ;;
    web-logs|webui-logs)
        shift
        service_logs "$@"
        ;;
    web-proxy-install|webui-proxy-install)
        shift
        install_web_proxy "$@"
        exit 0
        ;;
esac

if [ "$#" -eq 0 ]; then
    exec bash "$SCRIPT" --menu
fi

exec bash "$SCRIPT" "$@"
